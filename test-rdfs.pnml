                    </graphics>
                    <text>T5</text>
                </name>
                <graphics>
                    <position x="240" y="345"/>
                </graphics>
            </transition>
            <arc id="P0_to_T1" source="P0" target="T1" type="normal">
                <hlinscription>
                    <text>1'4</text>
                    <structure>
                        <numberof>
                            <subterm>
                                <numberconstant value="1">
                                    <positive/>
                                </numberconstant>
                            </subterm>
                            <subterm>
                                <finiteintrangeconstant value="4">
                                    <finiteintrange end="5" start="1"/>
                                </finiteintrangeconstant>
                            </subterm>
                        </numberof>
