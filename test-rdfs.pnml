            <arc id="P0_to_T5" source="P0" target="T5" type="normal">
                <hlinscription>
                    <text>1'x</text>
                    <structure>
                        <numberof>
                            <subterm>
                                <numberconstant value="1">
                                    <positive/>
                                </numberconstant>
                            </subterm>
                            <subterm>
