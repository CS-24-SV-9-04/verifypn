					</namedsort>
					<namedsort id="sf" name="sf">
						<productsort>
							<usersort declaration="site"/>
							<usersort declaration="file"/>
						</productsort>
					</namedsort>
					<!-- Declaration of user-defined color variables -->
					<variabledecl id="vars" name="vars">
						<usersort declaration="site"/>
					</variabledecl>
					<variabledecl id="varf" name="varf">
						<usersort declaration="file"/>
					</variabledecl>
