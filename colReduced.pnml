<?xml version="1.0"?>
<pnml xmlns="http://www.pnml.org/version-2009/grammar/pnml">
	<net id="MODELID" type="http://www.pnml.org/version-2009/grammar/symmetricnet">
		<name><text>MODELNAME</text></name>
		<!-- List of declarations -->
		<declaration>
			<structure>
				<declarations>
					<!-- Declaration of user-defined color classes (sorts) -->
					<namedsort id="file" name="file">
						<cyclicenumeration>
							<feconstant id="file1" name="1"/>
							<feconstant id="file2" name="2"/>
							<feconstant id="file3" name="3"/>
							<feconstant id="file4" name="4"/>
