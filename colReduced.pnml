					</variabledecl>
					<variabledecl id="Updatevarf" name="Updatevarf">
						<usersort declaration="file"/>
					</variabledecl>
					<variabledecl id="SendMsgUpdatevarsUpdatevars" name="SendMsgUpdatevarsUpdatevars">
						<usersort declaration="site"/>
					</variabledecl>
					<variabledecl id="SendMsgUpdatevarfUpdatevarf" name="SendMsgUpdatevarfUpdatevarf">
						<usersort declaration="file"/>
					</variabledecl>
