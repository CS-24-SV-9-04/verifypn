					</variabledecl>
					<variabledecl id="Changevarf" name="Changevarf">
						<usersort declaration="file"/>
					</variabledecl>
					<variabledecl id="AcquireChangevarsChangevars" name="AcquireChangevarsChangevars">
						<usersort declaration="site"/>
					</variabledecl>
					<variabledecl id="AcquireChangevarfChangevarf" name="AcquireChangevarfChangevarf">
