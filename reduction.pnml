					</structure>
				</type>
				<hlinitialMarking>
					<text>1'(Options1) + 1'(Options2)</text>
					<structure>
						<add>
							<subterm>
								<numberof>
									<subterm>
										<numberconstant value="1">
											<positive/>
										</numberconstant>
									</subterm>
									<subterm>
										<useroperator declaration="Options1"/>
									</subterm>
								</numberof>
							</subterm>
							<subterm>
								<numberof>
									<subterm>
										<numberconstant value="1">
											<positive/>
										</numberconstant>
									</subterm>
									<subterm>
										<useroperator declaration="Options2"/>
									</subterm>
								</numberof>
							</subterm>
						</add>
					</structure>
				</hlinitialMarking>
			</place>
			<place id="optionSlots">
				<name>
					<text>optionSlots</text>
				</name>
				<graphics>
					<position x="0" y="0"/>
				</graphics>
				<type>
					<text>Options</text>
					<structure>
						<usersort declaration="Options"/>
					</structure>
				</type>
			</place>
			<!-- List of transitions -->
			<transition id="elaborate3">
				<name>
					<text>elaborate3</text>
				</name>
				<graphics>
					<position x="0" y="0"/>
				</graphics>
				<condition>
					<text>(Quality6 lt varx and varx lte Quality8)</text>
					<structure>
						<and>
							<subterm>
								<lessthan>
									<subterm>
										<useroperator declaration="Quality6"/>
									</subterm>
									<subterm>
										<variable refvariable="varx"/>
									</subterm>
								</lessthan>
							</subterm>
							<subterm>
								<lessthanorequal>
									<subterm>
										<variable refvariable="varx"/>
									</subterm>
									<subterm>
										<useroperator declaration="Quality8"/>
									</subterm>
								</lessthanorequal>
							</subterm>
						</and>
					</structure>
				</condition>
			</transition>
			<transition id="elaborate2">
				<name>
					<text>elaborate2</text>
				</name>
				<graphics>
					<position x="0" y="0"/>
				</graphics>
				<condition>
					<text>(Quality4 lt varx and varx lte Quality6)</text>
					<structure>
						<and>
							<subterm>
								<lessthan>
									<subterm>
										<useroperator declaration="Quality4"/>
									</subterm>
									<subterm>
										<variable refvariable="varx"/>
									</subterm>
								</lessthan>
							</subterm>
							<subterm>
								<lessthanorequal>
									<subterm>
										<variable refvariable="varx"/>
									</subterm>
									<subterm>
										<useroperator declaration="Quality6"/>
									</subterm>
								</lessthanorequal>
							</subterm>
						</and>
					</structure>
				</condition>
			</transition>
			<transition id="elaborate1">
				<name>
					<text>elaborate1</text>
				</name>
				<graphics>
					<position x="0" y="0"/>
				</graphics>
				<condition>
					<text>(Quality2 lt varx and varx lte Quality4)</text>
					<structure>
						<and>
							<subterm>
								<lessthan>
									<subterm>
										<useroperator declaration="Quality2"/>
									</subterm>
									<subterm>
										<variable refvariable="varx"/>
									</subterm>
								</lessthan>
							</subterm>
							<subterm>
								<lessthanorequal>
									<subterm>
										<variable refvariable="varx"/>
									</subterm>
									<subterm>
										<useroperator declaration="Quality4"/>
									</subterm>
								</lessthanorequal>
							</subterm>
						</and>
					</structure>
				</condition>
			</transition>
			<transition id="serve">
				<name>
					<text>serve</text>
				</name>
				<graphics>
					<position x="0" y="0"/>
				</graphics>
			</transition>
			<transition id="elaborate0">
				<name>
					<text>elaborate0</text>
				</name>
				<graphics>
					<position x="0" y="0"/>
				</graphics>
				<condition>
					<text>varx lte Quality2</text>
					<structure>
						<lessthanorequal>
							<subterm>
								<variable refvariable="varx"/>
							</subterm>
							<subterm>
								<useroperator declaration="Quality2"/>
							</subterm>
						</lessthanorequal>
