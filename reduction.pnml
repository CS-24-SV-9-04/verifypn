				</graphics>
			</transition>
			<!-- List of arcs -->
			<arc id="wait_to_elaborate3" source="wait" target="elaborate3" type="normal">
				<name>
					<text>wait_to_elaborate3</text>
				</name>
				<hlinscription>
					<text>1'(varx)</text>
					<structure>
						<numberof>
							<subterm>
								<numberconstant value="1">
									<positive/>
								</numberconstant>
							</subterm>
							<subterm>
